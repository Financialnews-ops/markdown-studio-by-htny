{
  "name": "markdown-studio",
  "version": "2.0.1",
  "description": "Modern desktop Markdown editor with live preview, high-quality exports and independent pane controls — by HTNY Studios",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package:win": "electron-packager . \"Markdown Studio by HTNY Studios\" --platform=win32 --arch=x64 --icon=assets/icon.ico --overwrite",
    "dist:win": "electron-builder --win nsis --x64"
  },
  "author": "HTNY Studios",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/Financialnews-ops/markdown-studio-by-htny.git"
  },
  "homepage": "https://github.com/Financialnews-ops/markdown-studio-by-htny",
  "bugs": {
    "url": "https://github.com/Financialnews-ops/markdown-studio-by-htny/issues"
  },
  "keywords": [
    "markdown",
    "editor",
    "electron",
    "preview",
    "pdf",
    "docx",
    "windows",
    "desktop-app",
    "offline"
  ],
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.htnystudios.markdownstudio",
    "productName": "Markdown Studio by HTNY Studios",
    "copyright": "Copyright © 2026 HTNY Studios",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "lib/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Markdown Studio",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  }
}
